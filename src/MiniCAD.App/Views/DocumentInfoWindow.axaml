<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:docs="using:MiniCAD.Core.Documents"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="560" d:DesignHeight="520"
        x:Class="MiniCAD.App.Views.DocumentInfoWindow"
        Title="Dokument-Info"
        Width="560" Height="520"
        Background="{DynamicResource Brush.SurfaceApp}"
        Foreground="{DynamicResource Brush.TextBody}"
        CanResize="True" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Schließen" Click="OnClose" />
        </StackPanel>

        <!-- Top summary line -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,10">
            <TextBlock Grid.Row="0" Grid.Column="0" x:Name="ObjectsText" />
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DefinitionsText" />
            <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="BoundsText" Margin="0,4,0,0" />
            <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="ModelText" Margin="0,2,0,0" />
        </Grid>
        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource Brush.BorderSubtle}" Margin="0,0,0,8" />

        <Grid ColumnDefinitions="*,12,*">
            <!-- By type -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Objekte je Typ" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextMuted}" Margin="0,0,0,4" />
                <ScrollViewer>
                    <ItemsControl x:Name="TypesHost">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="docs:NamedCount">
                                <Grid ColumnDefinitions="*,60" Margin="0,2">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Count}" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- By layer / Teilbild -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Objekte je Layer" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextMuted}" Margin="0,0,0,4" />
                <ScrollViewer>
                    <StackPanel>
                        <ItemsControl x:Name="LayersHost">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="docs:NamedCount">
                                    <Grid ColumnDefinitions="*,60" Margin="0,2">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Count}" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Objekte je Teilbild" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextMuted}" Margin="0,10,0,4" />
                        <ItemsControl x:Name="PartialDrawingsHost">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="docs:NamedCount">
                                    <Grid ColumnDefinitions="*,60" Margin="0,2">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Count}" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
