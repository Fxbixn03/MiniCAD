<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="240"
        x:Class="MiniCAD.App.Views.FindReplaceWindow"
        Title="Text suchen &amp; ersetzen"
        Width="400" Height="240"
        Background="{DynamicResource Brush.SurfaceApp}"
        Foreground="{DynamicResource Brush.TextBody}"
        CanResize="False" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" Margin="0,0,0,10">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Suchen" VerticalAlignment="Center" Margin="0,0,8,6"
                       Foreground="{DynamicResource Brush.TextMuted}" />
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="FindBox" Margin="0,0,0,6" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Ersetzen" VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource Brush.TextMuted}" />
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="ReplaceBox" />
        </Grid>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="14" Margin="0,0,0,8">
            <CheckBox x:Name="MatchCaseCheck" Content="Groß-/Kleinschreibung" />
            <CheckBox x:Name="WholeWordCheck" Content="Ganzes Wort" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Treffer zählen" Click="OnCount" />
            <Button Content="Alle ersetzen" Click="OnReplaceAll" />
            <Button Content="Schließen" Click="OnClose" />
        </StackPanel>

        <Border Background="{DynamicResource Brush.SurfacePanel}" CornerRadius="4" Padding="10" VerticalAlignment="Top">
            <TextBlock x:Name="ResultText" TextWrapping="Wrap" Text="Suchbegriff eingeben." />
        </Border>
    </DockPanel>
</Window>
