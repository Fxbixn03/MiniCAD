<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniCAD.App.ViewModels"
        xmlns:converters="using:Avalonia.Data.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="380" d:DesignHeight="520"
        x:Class="MiniCAD.App.Views.LayersWindow"
        x:DataType="vm:StructurePanelViewModel"
        Title="Layer verwalten"
        Width="380" Height="520"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="14">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Content="Neu" Command="{Binding AddLayerCommand}" />
            <TextBlock Text="Layer" FontSize="16" FontWeight="SemiBold"
                       Foreground="#CFCFCF" VerticalAlignment="Center" />
        </DockPanel>

        <Button DockPanel.Dock="Bottom" Content="Schließen" HorizontalAlignment="Right"
                Margin="0,10,0,0" Click="OnClose" />

        <!-- Color editor for the selected layer -->
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0" Padding="10" CornerRadius="4"
                Background="#252528" BorderBrush="#3A3A40" BorderThickness="1"
                IsVisible="{Binding SelectedLayer, Converter={x:Static converters:ObjectConverters.IsNotNull}}">
            <StackPanel Spacing="8">
                <DockPanel>
                    <TextBlock Text="Farbe" FontWeight="SemiBold" Foreground="#CFCFCF" />
                    <TextBlock Text="{Binding SelectedLayer.ColorHex}" HorizontalAlignment="Right" Foreground="#888" />
                </DockPanel>
                <Grid ColumnDefinitions="16,*,38" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center" />
                    <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding SelectedLayer.ColorRed}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SelectedLayer.ColorRed, StringFormat='{}{0:0}'}"
                               VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#AAA" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center" />
                    <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding SelectedLayer.ColorGreen}" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SelectedLayer.ColorGreen, StringFormat='{}{0:0}'}"
                               VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#AAA" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center" />
                    <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding SelectedLayer.ColorBlue}" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding SelectedLayer.ColorBlue, StringFormat='{}{0:0}'}"
                               VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#AAA" />
                </Grid>
                <Border Height="24" CornerRadius="3" BorderBrush="#3A3A40" BorderThickness="1"
                        Background="{Binding SelectedLayer.ColorBrush}" />
            </StackPanel>
        </Border>

        <ListBox ItemsSource="{Binding Layers}"
                 SelectedItem="{Binding SelectedLayer}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:LayerItemViewModel">
                    <DockPanel>
                        <ComboBox DockPanel.Dock="Left" SelectedIndex="{Binding StateIndex}"
                                  Width="118" Margin="0,0,8,0" ToolTip.Tip="Aktiviert / Gesperrt / Deaktiviert">
                            <ComboBoxItem>Aktiviert</ComboBoxItem>
                            <ComboBoxItem>Gesperrt</ComboBoxItem>
                            <ComboBoxItem>Deaktiviert</ComboBoxItem>
                        </ComboBox>
                        <Border DockPanel.Dock="Left" Width="14" Height="14" CornerRadius="2"
                                Margin="0,0,8,0" VerticalAlignment="Center"
                                BorderBrush="#3A3A40" BorderThickness="1"
                                Background="{Binding ColorBrush}" />
                        <TextBox Text="{Binding Name}" BorderThickness="0" Background="Transparent"
                                 VerticalAlignment="Center" />
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>

</Window>
