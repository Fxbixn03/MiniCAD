<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniCAD.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="460" d:DesignHeight="500"
        x:Class="MiniCAD.App.Views.PartialDrawingsWindow"
        x:DataType="vm:PartialDrawingSelectionViewModel"
        Title="Teilbild-Auswahl"
        Width="460" Height="500"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="14">
        <TextBlock DockPanel.Dock="Top" Text="Teilbild-Auswahl" FontSize="16" FontWeight="SemiBold"
                   Foreground="#CFCFCF" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,10" TextWrapping="Wrap" Foreground="#9AA"
                   Text="Mehrere Teilbilder ankreuzen und den Status gemeinsam setzen, oder eines als aktuelles Teilbild wählen." />

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
            <Button Content="Alle" Command="{Binding SelectAllCommand}" />
            <Button Content="Keine" Command="{Binding SelectNoneCommand}" />
            <Border Width="1" Background="#444" Margin="4,2" />
            <Button Content="→ Aktiv" Command="{Binding SetActiveCommand}" />
            <Button Content="→ Passiv" Command="{Binding SetPassiveCommand}" />
            <Button Content="→ Aus" Command="{Binding SetOffCommand}" />
            <Border Width="1" Background="#444" Margin="4,2" />
            <Button Content="Als aktuell" Command="{Binding MakeCurrentCommand}" />
        </StackPanel>

        <Button DockPanel.Dock="Bottom" Content="Schließen" HorizontalAlignment="Right"
                Margin="0,10,0,0" Click="OnClose" />

        <ListBox ItemsSource="{Binding Rows}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PartialDrawingItemViewModel">
                    <DockPanel>
                        <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsSelected}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <ComboBox DockPanel.Dock="Left" SelectedIndex="{Binding StateIndex}"
                                  Width="110" Margin="0,0,8,0" ToolTip.Tip="Aktiv / Passiv (gedimmt) / Aus">
                            <ComboBoxItem>Aktiv</ComboBoxItem>
                            <ComboBoxItem>Passiv</ComboBoxItem>
                            <ComboBoxItem>Aus</ComboBoxItem>
                        </ComboBox>
                        <Border DockPanel.Dock="Right" CornerRadius="3" Padding="6,1" Margin="6,0,0,0"
                                VerticalAlignment="Center" Background="#1e3a8a" IsVisible="{Binding IsCurrent}">
                            <TextBlock Text="Aktuell" Foreground="#CFE" />
                        </Border>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
