<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniCAD.App.ViewModels"
        xmlns:toolbar="using:MiniCAD.App.ViewModels.Toolbar"
        xmlns:documents="using:MiniCAD.Core.Documents"
        xmlns:conv="using:MiniCAD.App.Converters"
        xmlns:sys="using:System"
        xmlns:controls="using:MiniCAD.App.Controls"
        xmlns:converters="using:Avalonia.Data.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
        x:Class="MiniCAD.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/logo.ico"
        Width="1100" Height="700"
        FontFamily="{StaticResource Font.Sans}"
        FontSize="{StaticResource Text.sm}"
        Background="{DynamicResource Brush.SurfaceApp}"
        Foreground="{DynamicResource Brush.TextBody}"
        Title="{Binding Title}">

    <Window.Resources>
        <!-- Re-point Fluent's accent (tab underline, list/text selection, focus, slider)
             at the MiniCAD engineering blue so every standard control reads on-brand. -->
        <Color x:Key="SystemAccentColor">#2563eb</Color>
        <Color x:Key="SystemAccentColorLight1">#5b94f7</Color>
        <Color x:Key="SystemAccentColorLight2">#93c5fd</Color>
        <Color x:Key="SystemAccentColorLight3">#bfd3fe</Color>
        <Color x:Key="SystemAccentColorDark1">#1d4fd0</Color>
        <Color x:Key="SystemAccentColorDark2">#1e3a8a</Color>
        <Color x:Key="SystemAccentColorDark3">#172e6b</Color>
    </Window.Resources>

    <Window.Styles>
        <StyleInclude Source="avares://MiniCAD.App/Theme/EditorStyles.axaml" />
    </Window.Styles>

    <Design.DataContext>
        <!-- Only used by the IDE previewer; the runtime DataContext is set in App.axaml.cs. -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel DragDrop.AllowDrop="True">
        <!-- ===== Top menu bar: wordmark · menus · document title · actions ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource Brush.SurfaceChrome}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" Height="44" Margin="12,0,10,0">

                <!-- Left: brand mark + menus -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Image Source="/Assets/logo.png" Width="22" Height="22" VerticalAlignment="Center" />
                    <TextBlock Classes="wordmark" Margin="0,0,4,0">
                        <Run Text="Mini" /><Run Text="CAD" Foreground="{DynamicResource Brush.Brand}" />
                    </TextBlock>

                    <Menu Classes="appmenu" Background="Transparent" VerticalAlignment="Center">
                        <MenuItem Header="_Datei">
                            <MenuItem Header="_Neues Projekt" Click="OnNewProject" InputGesture="Ctrl+N" />
                            <MenuItem Header="Projekt _öffnen…" Click="OnOpenProject" InputGesture="Ctrl+O" />
                            <Separator />
                            <MenuItem Header="_Speichern" Click="OnSaveProject" InputGesture="Ctrl+S" />
                            <MenuItem Header="Speichern _unter…" Click="OnSaveProjectAs" InputGesture="Ctrl+Shift+S" />
                            <Separator />
                            <MenuItem Header="3D-Mesh _importieren (STL/OBJ)…" Click="OnImportMesh" />
                            <MenuItem Header="3D-Modell _exportieren (STL/OBJ)…" Click="OnExportMesh" />
                            <Separator />
                            <MenuItem Header="_Beenden" Click="OnExit" />
                        </MenuItem>
                        <MenuItem Header="_Ansicht">
                            <MenuItem Header="_Zoom anpassen" Command="{Binding ZoomToFitCommand}" />
                            <Separator />
                            <MenuItem Header="3D _nebeneinander" ToggleType="CheckBox"
                                      IsChecked="{Binding SideBySide3D}"
                                      ToolTip.Tip="2D-Grundriss links, 3D-Modell rechts (live)" />
                            <MenuItem Header="3D-Fenster _abdocken" Click="OnDetach3D"
                                      ToolTip.Tip="3D-Ansicht als eigenes Fenster (auf einen zweiten Monitor verschiebbar)" />
                        </MenuItem>
                        <MenuItem Header="_Bearbeiten">
                            <MenuItem Header="_Verschieben" Command="{Binding ActivateMoveCommand}" InputGesture="M" />
                            <MenuItem Header="_Kopieren" Command="{Binding ActivateCopyCommand}" InputGesture="Shift+C" />
                            <MenuItem Header="_Drehen" Command="{Binding ActivateRotateCommand}" InputGesture="Shift+R" />
                            <MenuItem Header="_Spiegeln" Command="{Binding ActivateMirrorCommand}" InputGesture="Shift+M" />
                            <MenuItem Header="S_kalieren" Command="{Binding ActivateScaleCommand}" InputGesture="Shift+S" />
                            <MenuItem Header="_Parallele (Offset)" Command="{Binding ActivateOffsetCommand}" InputGesture="O" />
                            <MenuItem Header="S_tutzen / Dehnen" Command="{Binding ActivateTrimCommand}" InputGesture="T" />
                            <MenuItem Header="_Dehnen (Fenster)" Command="{Binding ActivateStretchCommand}" InputGesture="S" />
                            <MenuItem Header="_Abrundung / Fase" Command="{Binding ActivateFilletCommand}" InputGesture="Shift+F" />
                            <MenuItem Header="Trennen am _Punkt" Command="{Binding ActivateBreakAtPointCommand}" />
                            <MenuItem Header="_Bruch (zwei Punkte)" Command="{Binding ActivateBreakCommand}" />
                            <MenuItem Header="Polylinie bearbeiten">
                                <MenuItem Header="Stützpunkt _hinzufügen" Command="{Binding EditPolylineCommand}" CommandParameter="Add" />
                                <MenuItem Header="Stützpunkt _löschen" Command="{Binding EditPolylineCommand}" CommandParameter="Remove" />
                                <MenuItem Header="Gerade/_Bogen umschalten" Command="{Binding EditPolylineCommand}" CommandParameter="Arc" />
                            </MenuItem>
                            <MenuItem Header="_Array (Raster / polar)" Command="{Binding ActivateArrayCommand}" InputGesture="Shift+A" />
                            <Separator />
                            <MenuItem Header="Ä_hnliche auswählen (Typ + Layer)" Command="{Binding SelectSimilarCommand}" />
                            <MenuItem Header="Gleichen _Typ auswählen" Command="{Binding SelectSameTypeCommand}" />
                            <Separator />
                            <MenuItem Header="_Isolieren (übrige ausblenden)" Command="{Binding IsolateSelectionCommand}" />
                            <MenuItem Header="A_usblenden" Command="{Binding HideSelectionCommand}" />
                            <MenuItem Header="Alle _einblenden" Command="{Binding ShowAllCommand}" />
                            <Separator />
                            <MenuItem Header="_Gruppieren" Command="{Binding GroupSelectionCommand}" InputGesture="Ctrl+G" />
                            <MenuItem Header="Gruppierung auf_heben" Command="{Binding UngroupSelectionCommand}" InputGesture="Ctrl+Shift+G" />
                            <MenuItem Header="In _Hilfskonstruktion umwandeln" Command="{Binding ConvertConstructionCommand}" />
                            <Separator />
                            <MenuItem Header="_Zerlegen (Explodieren)" Command="{Binding ExplodeSelectionCommand}" InputGesture="Ctrl+Shift+X" />
                            <MenuItem Header="_Verbinden (Join)" Command="{Binding JoinSelectionCommand}" InputGesture="Ctrl+J" />
                            <MenuItem Header="_Bereinigen (Overkill)" Command="{Binding CleanupOverkillCommand}" />
                            <Separator />
                            <MenuItem Header="_Löschen" Command="{Binding DeleteSelectionCommand}" InputGesture="Delete" />
                        </MenuItem>
                        <MenuItem Header="_Werkzeuge">
                            <MenuItem Header="_Text / Beschriftung" Command="{Binding ActivateTextCommand}" InputGesture="X" />
                        <MenuItem Header="_Führungslinie / Callout" Command="{Binding ActivateLeaderCommand}" InputGesture="G" />
                        <MenuItem Header="_Bild als Unterlage…" Click="OnInsertImage" />
                        <MenuItem Header="_Maß (linear / ausgerichtet)" Command="{Binding ActivateLinearDimensionCommand}" InputGesture="D" />
                        <MenuItem Header="Maß (_Winkel)" Command="{Binding ActivateAngularDimensionCommand}" InputGesture="W" />
                        <MenuItem Header="Maß (_Radius / Durchmesser)" Command="{Binding ActivateRadialDimensionCommand}" InputGesture="Shift+D" />
                        <MenuItem Header="_Höhenkote" Command="{Binding ActivateElevationDimensionCommand}" InputGesture="H" />
                        <MenuItem Header="_Koordinatenmaß (Ordinate)" Command="{Binding ActivateOrdinateDimensionCommand}" InputGesture="I" />
                        <Separator />
                        <MenuItem Header="_Nullpunkt setzen" Command="{Binding ActivateSetNullPointCommand}" />
                            <MenuItem Header="Nullpunkt zu_rücksetzen" Command="{Binding ResetNullPointCommand}" />
                            <Separator />
                            <MenuItem Header="_Standard-Layer einfügen" Command="{Binding AddStandardLayersCommand}" />
                            <Separator />
                            <MenuItem Header="3D-_Quader einfügen" Command="{Binding InsertPrimitive3DCommand}" CommandParameter="Box" />
                            <MenuItem Header="_Extrudieren (2D-Profil → 3D)" Command="{Binding ExtrudeSelectionCommand}" />
                            <MenuItem Header="_Rotationskörper (Revolve)" Command="{Binding RevolveSelectionCommand}" />
                            <MenuItem Header="_Arbeitsebene">
                                <MenuItem Header="_Draufsicht (XY)" Command="{Binding SetWorkPlaneCommand}" CommandParameter="Top" />
                                <MenuItem Header="_Vorn (XZ)" Command="{Binding SetWorkPlaneCommand}" CommandParameter="Front" />
                                <MenuItem Header="_Seite (YZ)" Command="{Binding SetWorkPlaneCommand}" CommandParameter="Right" />
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="_Schnittzeichen platzieren" Command="{Binding PlaceSectionMarkCommand}" />
                            <MenuItem Header="_Detailzeichen platzieren" Command="{Binding PlaceDetailMarkCommand}" />
                            <MenuItem Header="Schnitt aus _Modell erzeugen (#93)" Command="{Binding GenerateSectionCommand}" />
                            <MenuItem Header="_Massenauszug (3D)…" Click="OnMassTakeoff" />
                            <Separator />
                            <MenuItem Header="Dokument-_Info / Statistik…" Click="OnDocumentInfo" />
                            <MenuItem Header="_Bereinigen (Purge)…" Click="OnPurge" />
                            <MenuItem Header="_Prüfen &amp; Reparieren (Audit)…" Click="OnAudit" />
                            <Separator />
                            <MenuItem Header="_Teilbild-Auswahl…" Click="OnPartialDrawingSelection" />
                            <Separator />
                            <MenuItem Header="_Einstellungen…" Click="OnOpenSettings" />
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <!-- Center: document title + save state -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ProjectName}" Classes="panelheading" />
                    <Border Classes="badge warn" IsVisible="{Binding IsDirty}">
                        <TextBlock Text="Ungespeichert" />
                    </Border>
                    <Border Classes="badge ok" IsVisible="{Binding !IsDirty}">
                        <TextBlock Text="Gespeichert" />
                    </Border>
                </StackPanel>

                <!-- Right: theme toggle + status badge + primary action -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ToggleButton Classes="chrometoggle" IsChecked="{Binding Settings.IsDarkMode}"
                                  ToolTip.Tip="Helles / dunkles Design umschalten">
                        <Panel>
                            <Path Classes="ico" Data="{StaticResource Icon.Moon}" IsVisible="{Binding !Settings.IsDarkMode}" />
                            <Path Classes="ico" Data="{StaticResource Icon.Sun}" IsVisible="{Binding Settings.IsDarkMode}" />
                        </Panel>
                    </ToggleButton>
                    <Border Classes="badge brand">
                        <TextBlock Text="Beta" />
                    </Border>
                    <Button Classes="primary" Content="Speichern" Click="OnSaveProject" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Bottom: monospace status strip ===== -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChrome}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0" Height="28">
            <DockPanel LastChildFill="False">
                <Border DockPanel.Dock="Left" Background="{DynamicResource Brush.SurfaceSunken}" CornerRadius="4"
                        Padding="8,2" Margin="10,4" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                    <TextBlock Classes="mono" Foreground="{DynamicResource Brush.StatusInfo}" Text="{Binding CursorText}" />
                </Border>
                <Border DockPanel.Dock="Left" Background="{DynamicResource Brush.SurfaceSunken}" CornerRadius="4"
                        Padding="8,2" Margin="0,4,4,4" BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1"
                        IsVisible="{Binding PolarReadout, Converter={x:Static converters:StringConverters.IsNotNullOrEmpty}}">
                    <TextBlock Classes="mono" Foreground="{DynamicResource Brush.StatusWarn}" Text="{Binding PolarReadout}" />
                </Border>
                <TextBlock DockPanel.Dock="Left" Classes="mono" Margin="6,0" Foreground="{DynamicResource Brush.TextBody}"
                           Text="{Binding StatusText}" />
                <TextBlock DockPanel.Dock="Left" Classes="mono" Margin="6,0" Foreground="{DynamicResource Brush.StatusOk}"
                           Text="{Binding StatusMessage}" />
                <TextBlock DockPanel.Dock="Right" Classes="mono" Margin="12,0" Foreground="{DynamicResource Brush.TextFaint}"
                           Text="MMT = verschieben · Rad = zoom · Esc = abbrechen · Entf = löschen" />
            </DockPanel>
        </Border>

        <!-- Inline array parameters (rectangular / polar), shown while that tool is active. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsArrayActive}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding ArrayOptions}" x:DataType="vm:ArrayOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="ARRAY" VerticalAlignment="Center" />
                <ToggleButton IsChecked="{Binding IsPolar}" Content="{Binding ModeLabel}" MinWidth="92"
                              ToolTip.Tip="Rechteckig (Raster) ⟷ Polar (um Mittelpunkt)" />

                <!-- Rectangular fields -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" IsVisible="{Binding !IsPolar}">
                    <TextBlock Text="Reihen" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                    <TextBox Width="48" Text="{Binding RowsText}" FontFamily="{StaticResource Font.Mono}" />
                    <TextBlock Text="Spalten" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                    <TextBox Width="48" Text="{Binding ColumnsText}" FontFamily="{StaticResource Font.Mono}" />
                    <TextBlock Text="dX" Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                    <TextBox Width="60" Text="{Binding SpacingXText}" FontFamily="{StaticResource Font.Mono}" />
                    <TextBlock Text="dY" Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                    <TextBox Width="60" Text="{Binding SpacingYText}" FontFamily="{StaticResource Font.Mono}" />
                    <TextBlock Text="Klick oder ⏎ bestätigt" Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>

                <!-- Polar fields -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" IsVisible="{Binding IsPolar}">
                    <TextBlock Text="Anzahl" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                    <TextBox Width="48" Text="{Binding CountText}" FontFamily="{StaticResource Font.Mono}" />
                    <TextBlock Text="Winkel°" Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                    <TextBox Width="60" Text="{Binding AngleText}" FontFamily="{StaticResource Font.Mono}" />
                    <TextBlock Text="Mittelpunkt klicken" Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="6,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Inline marker style/size, shown while the point tool is active. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsPointActive}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding PointOptions}" x:DataType="vm:PointOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="PUNKT" VerticalAlignment="Center" />
                <TextBlock Text="Stil" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                <ComboBox MinWidth="96" ItemsSource="{Binding StyleOptions}" SelectedItem="{Binding Style}" />
                <TextBlock Text="Größe" Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                <TextBox Width="60" Text="{Binding SizeText}" FontFamily="{StaticResource Font.Mono}" />
            </StackPanel>
        </Border>

        <!-- Inline text options (cap height, alignment, multi-line), shown while the text tool is active. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsTextActive}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding TextOptions}" x:DataType="vm:TextOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="TEXT" VerticalAlignment="Center" />
                <TextBlock Text="Stil" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                <ComboBox MinWidth="110" ItemsSource="{Binding Styles}" SelectedItem="{Binding ActiveStyle}"
                          ToolTip.Tip="Aktiver Textstil (Schriftart/Breitenfaktor)" />
                <TextBlock Text="Höhe" Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                <TextBox Width="60" Text="{Binding HeightText}" FontFamily="{StaticResource Font.Mono}" />
                <TextBlock Text="H" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                <ComboBox MinWidth="92" ItemsSource="{Binding HorizontalOptions}" SelectedItem="{Binding HorizontalAlignment}" />
                <TextBlock Text="V" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                <ComboBox MinWidth="92" ItemsSource="{Binding VerticalOptions}" SelectedItem="{Binding VerticalAlignment}" />
                <CheckBox Content="Mehrzeilig" IsChecked="{Binding Multiline}" VerticalAlignment="Center" Margin="6,0,0,0" />
                <TextBlock Text="Klicken, tippen, ⏎ bestätigt · Doppelklick bearbeitet" Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Inline leader options (label height), shown while the leader tool is active. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsLeaderActive}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding LeaderOptions}" x:DataType="vm:LeaderOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="FÜHRUNG" VerticalAlignment="Center" />
                <TextBlock Text="Texthöhe" Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                <TextBox Width="60" Text="{Binding HeightText}" FontFamily="{StaticResource Font.Mono}" />
                <TextBlock Text="Pfeilspitze klicken, Knickpunkte setzen, ⏎/Rechtsklick beendet, dann Text tippen"
                           Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Inline dimension orientation, shown while the linear dimension tool is active. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsLinearDimensionActive}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding DimensionOptions}" x:DataType="vm:DimensionOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="MASS" VerticalAlignment="Center" />
                <TextBlock Text="Art" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                <ComboBox MinWidth="120" ItemsSource="{Binding KindOptions}" SelectedItem="{Binding Kind}" />
                <TextBlock Text="Folge" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                <ComboBox MinWidth="110" ItemsSource="{Binding ContinueModeOptions}" SelectedItem="{Binding ContinueMode}"
                          ToolTip.Tip="Einzeln / Kette (fortgesetzt) / Basislinie" />
                <TextBlock Text="1./2. Punkt, dann Maßlinie · Folge: weiter klicken" Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Inline Z value, shown while the elevation (Höhenkote) tool is active. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsElevationDimensionActive}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding ElevationDimensionOptions}" x:DataType="vm:ElevationDimensionOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="HÖHENKOTE" VerticalAlignment="Center" />
                <TextBlock Text="Z" Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                <TextBox Width="80" Text="{Binding ZText}" FontFamily="{StaticResource Font.Mono}" />
                <TextBlock Text="Punkt klicken setzt die Höhenkote (±0 / +/-)" Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Inline radius/diameter toggle, shown while the radial dimension tool is active. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsRadialDimensionActive}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding RadialDimensionOptions}" x:DataType="vm:RadialDimensionOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="RADIALMASS" VerticalAlignment="Center" />
                <ToggleButton IsChecked="{Binding IsDiameter}" Content="{Binding ModeLabel}" MinWidth="120"
                              ToolTip.Tip="Radius R ⟷ Durchmesser ⌀" />
                <TextBlock Text="Kreis/Bogen wählen, dann Textposition klicken" Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Inline arc-mode selector, shown while the arc tool is active. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsArcActive}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding ArcOptions}" x:DataType="vm:ArcOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="BOGEN" VerticalAlignment="Center" />
                <ToggleButton IsChecked="{Binding IsCenterMode}" Content="{Binding ModeLabel}" MinWidth="100"
                              ToolTip.Tip="3-Punkt ⟷ Mittelpunkt/Start/Ende" />
                <TextBlock Text="{Binding Hint}" Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Inline fillet/chamfer parameters, shown while that tool is active. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsFilletActive}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding FilletOptions}" x:DataType="vm:FilletOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="ECKE" VerticalAlignment="Center" />
                <ToggleButton IsChecked="{Binding IsChamfer}" Content="{Binding ModeLabel}" MinWidth="92"
                              ToolTip.Tip="Abrundung (Bogen) ⟷ Fase (Gerade)" />
                <TextBlock Text="{Binding DistanceLabel}" Foreground="{DynamicResource Brush.StatusInfo}"
                           FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                <TextBox Width="80" Text="{Binding DistanceText}" FontFamily="{StaticResource Font.Mono}" />
                <TextBlock Text="Erste Linie wählen, dann zweite. 0 = scharfe Ecke."
                           Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- Inline wall/beam options (Anschlag + Dicke + Höhe), shown while drawing walls/beams. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsVisible="{Binding IsWallOptionsVisible}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding WallOptions}" x:DataType="vm:WallOptionsViewModel">
                <TextBlock Classes="eyebrow" Text="ANSCHLAG" VerticalAlignment="Center" />
                <ToggleButton Content="Mitte" IsChecked="{Binding IsCenter}" MinWidth="56"
                              Command="{Binding SetReferenceCommand}" CommandParameter="Center"
                              ToolTip.Tip="Achse (Mittellinie) als Bezug" />
                <ToggleButton Content="Links" IsChecked="{Binding IsLeft}" MinWidth="56"
                              Command="{Binding SetReferenceCommand}" CommandParameter="Left"
                              ToolTip.Tip="Linke Laibung als Bezug" />
                <ToggleButton Content="Rechts" IsChecked="{Binding IsRight}" MinWidth="56"
                              Command="{Binding SetReferenceCommand}" CommandParameter="Right"
                              ToolTip.Tip="Rechte Laibung als Bezug" />
                <Border Width="1" Background="{DynamicResource Brush.BorderStrong}" Margin="4,2" />
                <TextBlock Text="DICKE" Foreground="{DynamicResource Brush.StatusInfo}"
                           FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                <TextBox Width="70" Text="{Binding ThicknessText}" FontFamily="{StaticResource Font.Mono}" />
                <TextBlock Text="HÖHE" Foreground="{DynamicResource Brush.StatusInfo}"
                           FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                <TextBox Width="70" Text="{Binding HeightText}" FontFamily="{StaticResource Font.Mono}" />
            </StackPanel>
        </Border>

        <!-- Allplan-style coordinate entry: type X/Y and press Enter to place the point. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource Brush.SurfaceChromeAlt}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="0,1,0,0"
                IsEnabled="{Binding CoordinateInput.IsEnabled}">
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="10,6" VerticalAlignment="Center"
                        DataContext="{Binding CoordinateInput}" x:DataType="vm:CoordinateInputViewModel">
                <TextBlock Classes="eyebrow" Text="KOORDINATE" VerticalAlignment="Center" />
                <ToggleButton IsChecked="{Binding IsRelative}" Content="{Binding ModeLabel}" MinWidth="74"
                              ToolTip.Tip="Absolut (vom Nullpunkt) ⟷ Relativ (vom letzten Punkt)" />
                <TextBlock Text="X" Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                <TextBox Width="92" Text="{Binding XText}" FontFamily="{StaticResource Font.Mono}" KeyDown="OnCoordinateKeyDown" />
                <TextBlock Text="Y" Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" VerticalAlignment="Center" />
                <TextBox Width="92" Text="{Binding YText}" FontFamily="{StaticResource Font.Mono}" KeyDown="OnCoordinateKeyDown" />
                <Button Content="Setzen ⏎" Command="{Binding CommitCommand}" />
                <TextBlock Text="{Binding Hint}" Foreground="{DynamicResource Brush.StatusWarn}" VerticalAlignment="Center" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <!-- ===== Configurable tool rail (dockable + scrollable, data-driven) ===== -->
        <Border DockPanel.Dock="{Binding Toolbar.PanelDock}" Background="{DynamicResource Brush.SurfaceChrome}"
                BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="{Binding Toolbar.HandleDock}" Margin="2" Padding="4"
                        Background="Transparent" Cursor="Hand" PointerPressed="OnToolbarHandlePressed"
                        ToolTip.Tip="Werkzeugleiste an einen Rand ziehen (Links/Rechts/Oben/Unten)">
                    <Path Classes="ico" Data="M5,4 H19 M5,9 H19 M5,14 H19 M5,19 H19" />
                </Border>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Toolbar.Groups}" Margin="3">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="{Binding Toolbar.Orientation}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="toolbar:ToolGroupViewModel">
                              <StackPanel Orientation="{Binding Orientation}" Spacing="1">
                                <Border Background="Transparent" Cursor="Hand" Padding="2"
                                        PointerPressed="OnToolGroupGripPressed"
                                        ToolTip.Tip="Block ziehen, um die Reihenfolge zu ändern">
                                    <Path Classes="ico" Opacity="0.45"
                                          Data="M9,5 H11 V7 H9 Z M13,5 H15 V7 H13 Z M9,11 H11 V13 H9 Z M13,11 H15 V13 H13 Z M9,17 H11 V19 H9 Z M13,17 H15 V19 H13 Z" />
                                </Border>
                                <ItemsControl ItemsSource="{Binding Items}" Margin="1">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="{Binding Orientation}" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="toolbar:ToolbarItemViewModel">
                                            <Panel IsVisible="{Binding IsVisible}" Margin="2">
                                                <Button Classes="rail" IsVisible="{Binding !IsToggle}"
                                                        Classes.active="{Binding IsActive}" Command="{Binding Command}"
                                                        ToolTip.Tip="{Binding Tooltip}">
                                                    <Path Classes="ico" Data="{Binding Icon}" />
                                                </Button>
                                                <ToggleButton Classes="rail" IsVisible="{Binding IsToggle}"
                                                              IsChecked="{Binding IsChecked}" ToolTip.Tip="{Binding Tooltip}">
                                                    <Path Classes="ico" Data="{Binding Icon}" />
                                                </ToggleButton>
                                            </Panel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== Canvas | splitter | docked right palette (resizable in width) ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="300" MinWidth="230" MaxWidth="600" />
            </Grid.ColumnDefinitions>

            <!-- 2D plan | optional side-by-side live 3D pane -->
            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="150" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0" Padding="0">
                <TabItem Header="2D">
                    <Panel>
                        <controls:CadCanvasControl x:Name="Canvas"
                                                   Document="{Binding Document}" Viewport="{Binding Viewport}" Tools="{Binding Tools}"
                                                   ShowGrid="{Binding Settings.ShowGrid}" SceneBackground="{Binding Settings.BackgroundColor}" />

                        <!-- In-place text editor, positioned over the canvas at the insertion point (code-behind). -->
                        <TextBox x:Name="InlineTextEditor" IsVisible="False"
                                 HorizontalAlignment="Left" VerticalAlignment="Top" MinWidth="80"
                                 FontFamily="{StaticResource Font.Mono}" Padding="4,2"
                                 Background="{DynamicResource Brush.SurfaceChromeAlt}" Foreground="{DynamicResource Brush.TextBody}"
                                 BorderBrush="{DynamicResource Brush.Brand}" BorderThickness="1"
                                 KeyDown="OnInlineTextEditorKeyDown" LostFocus="OnInlineTextEditorLostFocus" />

                        <!-- Direct length entry at the crosshair (Allplan-style): type a length while drawing. -->
                        <StackPanel x:Name="DistanceInputBox" IsVisible="False" Orientation="Horizontal" Spacing="4"
                                    HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Background="{DynamicResource Brush.SurfaceChromeAlt}">
                            <TextBlock Text="Länge" VerticalAlignment="Center" Margin="6,0,0,0"
                                       Foreground="{DynamicResource Brush.StatusInfo}" FontFamily="{StaticResource Font.Mono}" />
                            <TextBox x:Name="DistanceInput" MinWidth="80" FontFamily="{StaticResource Font.Mono}" Padding="4,2"
                                     Background="{DynamicResource Brush.SurfaceChromeAlt}" Foreground="{DynamicResource Brush.TextBody}"
                                     BorderBrush="{DynamicResource Brush.Brand}" BorderThickness="1"
                                     KeyDown="OnDistanceInputKeyDown" LostFocus="OnDistanceInputLostFocus" />
                        </StackPanel>
                    </Panel>
                </TabItem>
                <TabItem Header="3D">
                    <DockPanel>
                        <WrapPanel DockPanel.Dock="Top" Margin="6" Background="{DynamicResource Brush.SurfaceChrome}">
                            <WrapPanel.Styles>
                                <Style Selector="Button"><Setter Property="Margin" Value="2" /></Style>
                            </WrapPanel.Styles>
                            <Button Content="Iso" Command="{Binding SetView3DCommand}" CommandParameter="Iso" />
                            <Button Content="Oben" Command="{Binding SetView3DCommand}" CommandParameter="Top" />
                            <Button Content="Unten" Command="{Binding SetView3DCommand}" CommandParameter="Bottom" />
                            <Button Content="Vorn" Command="{Binding SetView3DCommand}" CommandParameter="Front" />
                            <Button Content="Hinten" Command="{Binding SetView3DCommand}" CommandParameter="Back" />
                            <Button Content="Rechts" Command="{Binding SetView3DCommand}" CommandParameter="Right" />
                            <Button Content="Links" Command="{Binding SetView3DCommand}" CommandParameter="Left" />
                            <Button Content="{Binding ProjectionLabel}" Command="{Binding ToggleProjectionCommand}"
                                    ToolTip.Tip="Perspektive / Parallelprojektion umschalten" />
                            <Border Width="1" Background="{DynamicResource Brush.BorderStrong}" Margin="4,2" />
                            <Button Content="Quader" Command="{Binding InsertPrimitive3DCommand}" CommandParameter="Box" />
                            <Button Content="Zylinder" Command="{Binding InsertPrimitive3DCommand}" CommandParameter="Cylinder" />
                            <Button Content="Kugel" Command="{Binding InsertPrimitive3DCommand}" CommandParameter="Sphere" />
                            <Button Content="Kegel" Command="{Binding InsertPrimitive3DCommand}" CommandParameter="Cone" />
                            <Border Width="1" Background="{DynamicResource Brush.BorderStrong}" Margin="4,2" />
                            <Button Content="∪" Command="{Binding BooleanOpCommand}" CommandParameter="Union" ToolTip.Tip="Vereinen (CSG)" />
                            <Button Content="∖" Command="{Binding BooleanOpCommand}" CommandParameter="Subtract" ToolTip.Tip="Abziehen (CSG)" />
                            <Button Content="∩" Command="{Binding BooleanOpCommand}" CommandParameter="Intersect" ToolTip.Tip="Schnittmenge (CSG)" />
                            <Border Width="1" Background="{DynamicResource Brush.BorderStrong}" Margin="4,2" />
                            <TextBlock Text="Auswahl:" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="4,0,0,0" />
                            <Button Content="X−" Command="{Binding MoveModel3DCommand}" CommandParameter="X-" ToolTip.Tip="Verschieben −X" />
                            <Button Content="X+" Command="{Binding MoveModel3DCommand}" CommandParameter="X+" />
                            <Button Content="Y−" Command="{Binding MoveModel3DCommand}" CommandParameter="Y-" />
                            <Button Content="Y+" Command="{Binding MoveModel3DCommand}" CommandParameter="Y+" />
                            <Button Content="Z−" Command="{Binding MoveModel3DCommand}" CommandParameter="Z-" />
                            <Button Content="Z+" Command="{Binding MoveModel3DCommand}" CommandParameter="Z+" />
                            <Button Content="⟲" Command="{Binding RotateModel3DCommand}" CommandParameter="Z+" ToolTip.Tip="Drehen +90° (Z)" />
                            <Button Content="⟳" Command="{Binding RotateModel3DCommand}" CommandParameter="Z-" ToolTip.Tip="Drehen −90° (Z)" />
                            <Button Content="＋" Command="{Binding ScaleModel3DCommand}" CommandParameter="Up" ToolTip.Tip="Vergrößern" />
                            <Button Content="－" Command="{Binding ScaleModel3DCommand}" CommandParameter="Down" ToolTip.Tip="Verkleinern" />
                            <Button Content="Kopie" Command="{Binding DuplicateModel3DCommand}" ToolTip.Tip="Duplizieren" />
                            <Button Content="Löschen" Command="{Binding DeleteModel3DCommand}" />
                            <Border Width="1" Background="{DynamicResource Brush.BorderStrong}" Margin="4,2" />
                            <Button Content="Draht" Command="{Binding SetRenderModeCommand}" CommandParameter="Wireframe" />
                            <Button Content="Verdeckt" Command="{Binding SetRenderModeCommand}" CommandParameter="HiddenLine" />
                            <Button Content="Schattiert" Command="{Binding SetRenderModeCommand}" CommandParameter="Shaded" />
                            <ToggleButton Content="Boden" IsChecked="{Binding ShowGround3D}" Margin="2"
                                          ToolTip.Tip="Bodenraster &amp; Achsenkreuz ein/aus" />
                            <ToggleButton Content="Legende" IsChecked="{Binding ShowMaterialLegend}" Margin="2"
                                          ToolTip.Tip="Material-Legende ein/aus" />
                            <Border Width="1" Background="{DynamicResource Brush.BorderStrong}" Margin="4,2" />
                            <Button Content="Abdocken ⧉" Click="OnDetach3D" />
                        </WrapPanel>
                        <controls:Cad3DView Document="{Binding Document}" Camera="{Binding Camera3D}"
                                            Mode="{Binding View3DMode}" SelectedModel="{Binding Selected3DModel}"
                                            ShowGround="{Binding ShowGround3D}"
                                            ShowLegend="{Binding ShowMaterialLegend}" />
                    </DockPanel>
                </TabItem>
            </TabControl>

            <!-- Side-by-side live 3D pane (left 2D, right 3D); toggled via Ansicht ▸ 3D nebeneinander -->
            <Border Grid.Column="1" Width="4" IsVisible="{Binding SideBySide3D}"
                    Background="{DynamicResource Brush.BorderStrong}" />
            <DockPanel Grid.Column="2" Width="460" IsVisible="{Binding SideBySide3D}"
                       Background="{DynamicResource Brush.SurfaceChrome}">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="6">
                    <Button Content="Iso" Command="{Binding SetSideView3DCommand}" CommandParameter="Iso" />
                    <Button Content="Oben" Command="{Binding SetSideView3DCommand}" CommandParameter="Top" />
                    <Button Content="Vorn" Command="{Binding SetSideView3DCommand}" CommandParameter="Front" />
                    <Button Content="Rechts" Command="{Binding SetSideView3DCommand}" CommandParameter="Right" />
                    <Border Width="1" Background="{DynamicResource Brush.BorderStrong}" Margin="4,2" />
                    <Button Content="Draht" Command="{Binding SetRenderModeCommand}" CommandParameter="Wireframe" />
                    <Button Content="Verdeckt" Command="{Binding SetRenderModeCommand}" CommandParameter="HiddenLine" />
                    <Button Content="Schattiert" Command="{Binding SetRenderModeCommand}" CommandParameter="Shaded" />
                </StackPanel>
                <controls:Cad3DView Document="{Binding Document}" Camera="{Binding SideCamera3D}"
                                    Mode="{Binding View3DMode}" SelectedModel="{Binding Selected3DModel}"
                                    ShowGround="{Binding ShowGround3D}"
                                            ShowLegend="{Binding ShowMaterialLegend}" />
            </DockPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" Background="{DynamicResource Brush.BorderStrong}"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" />

            <Border Grid.Column="2" Background="{DynamicResource Brush.SurfacePanel}"
                    BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1,0,0,0">
                <TabControl Classes="palette" TabStripPlacement="Bottom" Padding="0">

                    <!-- ===== Eigenschaften (Attribute) ===== -->
                    <TabItem ToolTip.Tip="Eigenschaften">
                        <TabItem.Header>
                            <Border Classes="tabicon">
                                <Path Classes="icotab" Width="22" Height="22" Data="{StaticResource Icon.Properties}" />
                            </Border>
                        </TabItem.Header>
                        <ScrollViewer>
                            <StackPanel Margin="12" Spacing="12" DataContext="{Binding Attributes}"
                                        x:DataType="vm:AttributesViewModel">
                                <TextBlock Text="{Binding Summary}" Classes="panelheading" />

                                <TextBlock Text="Keine Auswahl. Wähle ein Objekt, um seine Eigenschaften zu bearbeiten."
                                           Foreground="{DynamicResource Brush.TextMuted}" TextWrapping="Wrap"
                                           IsVisible="{Binding !HasSelection}" />

                                <StackPanel Spacing="10" IsVisible="{Binding HasSelection}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="eyebrow" Text="LAYER" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding LayerOptions}"
                                                  SelectedItem="{Binding SelectedLayer}" />
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="eyebrow" Text="TEILBILD" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding PartialDrawingOptions}"
                                                  SelectedItem="{Binding SelectedPartialDrawing}" />
                                    </StackPanel>

                                    <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />

                                    <CheckBox Content="Eigener Linienstil" IsChecked="{Binding UseStrokeOverride}" />
                                    <StackPanel Spacing="6" IsEnabled="{Binding UseStrokeOverride}">
                                        <Grid ColumnDefinitions="16,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center" />
                                            <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding StrokeRed}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center" />
                                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding StrokeGreen}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center" />
                                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding StrokeBlue}" />
                                        </Grid>
                                        <DockPanel>
                                            <TextBlock Text="Stärke" Foreground="{DynamicResource Brush.TextMuted}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding StrokeWidth, StringFormat='{}{0:0.0} px'}"
                                                       Classes="mono" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </DockPanel>
                                        <Slider Minimum="0.25" Maximum="8" Value="{Binding StrokeWidth}" />
                                        <Border Height="20" CornerRadius="4" BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1"
                                                Background="{Binding StrokeBrush}" />
                                        <TextBlock Classes="eyebrow" Text="LINIENTYP" Margin="0,4,0,0" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding StrokeLineTypeOptions}"
                                                  SelectedItem="{Binding StrokeLineType}" />
                                        <TextBlock Classes="eyebrow" Text="LINIENSTÄRKE" Margin="0,4,0,0" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding StrokeLineWeightOptions}"
                                                  SelectedItem="{Binding StrokeLineWeight}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate x:DataType="sys:Double">
                                                    <TextBlock Text="{Binding Converter={x:Static conv:LineWeightLabelConverter.Instance}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Spacing="4" IsVisible="{Binding CanFill}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <TextBlock Classes="eyebrow" Text="FÜLLUNG (MUSTER)" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding FillOptions}"
                                                  SelectedItem="{Binding SelectedFill}" />
                                    </StackPanel>

                                    <StackPanel Spacing="6" IsVisible="{Binding CanFill}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <CheckBox Content="Fläche füllen (Vollton/Verlauf)" IsChecked="{Binding UseAreaFill}" />
                                        <StackPanel Spacing="6" IsEnabled="{Binding UseAreaFill}">
                                            <Grid ColumnDefinitions="16,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center" />
                                                <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding AreaRed}" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center" />
                                                <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding AreaGreen}" />
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center" />
                                                <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding AreaBlue}" />
                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="α" VerticalAlignment="Center" />
                                                <Slider Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding AreaAlpha}" />
                                            </Grid>
                                            <Border Height="18" CornerRadius="4" BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1"
                                                    Background="{Binding AreaBrush}" />
                                            <CheckBox Content="Verlauf (2. Farbe)" IsChecked="{Binding AreaGradient}" />
                                            <StackPanel Spacing="6" IsVisible="{Binding AreaGradient}">
                                                <Grid ColumnDefinitions="16,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center" />
                                                    <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding Area2Red}" />
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center" />
                                                    <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding Area2Green}" />
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center" />
                                                    <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding Area2Blue}" />
                                                </Grid>
                                                <DockPanel>
                                                    <TextBlock Text="Winkel" Foreground="{DynamicResource Brush.TextMuted}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding AreaAngle, StringFormat='{}{0:0}°'}" Classes="mono" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextMuted}" />
                                                </DockPanel>
                                                <Slider Minimum="0" Maximum="180" Value="{Binding AreaAngle}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="4" IsVisible="{Binding CanSetTextStyle}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <TextBlock Classes="eyebrow" Text="TEXTSTIL" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding TextStyleOptions}"
                                                  SelectedItem="{Binding SelectedTextStyle}" />
                                    </StackPanel>

                                    <StackPanel Spacing="6" IsVisible="{Binding IsWall}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <TextBlock Classes="eyebrow" Text="WAND" />
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Dicke" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding WallThickness}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Wanddicke in Zeichnungseinheiten" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Höhe" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding WallHeight}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Wandhöhe (Z-Ausdehnung)" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Basis-Z" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding WallBaseElevation}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Unterkante der Wand (z. B. 0 = Boden, 10 = beginnt bei Z=10)" />
                                        </DockPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="6" IsVisible="{Binding IsOpening}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <TextBlock Classes="eyebrow" Text="AUSSPARUNG / ÖFFNUNG" />
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Breite" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding OpeningWidth}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Breite quer zur Achse (muss die Wand durchdringen)" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Höhe" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding OpeningHeight}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Z-Ausdehnung der Aussparung" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Basis-Z" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding OpeningBaseElevation}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Unterkante (z. B. 0 = Tür, 900 = Fensterbrüstung)" />
                                        </DockPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="6" IsVisible="{Binding IsColumn}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <TextBlock Classes="eyebrow" Text="STÜTZE" />
                                        <CheckBox Content="Rund" IsChecked="{Binding ColumnRound}" />
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Breite/⌀" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding ColumnWidth}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Breite (X) bzw. Durchmesser bei runder Stütze" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Tiefe" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding ColumnDepth}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Tiefe (Y), nur bei rechteckiger Stütze" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Höhe" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding ColumnHeight}" FontFamily="{StaticResource Font.Mono}" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Basis-Z" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding ColumnBaseElevation}" FontFamily="{StaticResource Font.Mono}" />
                                        </DockPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="6" IsVisible="{Binding IsSlab}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <TextBlock Classes="eyebrow" Text="DECKE / PLATTE" />
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Dicke" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding SlabThickness}" FontFamily="{StaticResource Font.Mono}" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Basis-Z" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding SlabBaseElevation}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Unterkante der Decke" />
                                        </DockPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="6" IsVisible="{Binding IsBeam}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <TextBlock Classes="eyebrow" Text="UNTERZUG / TRÄGER" />
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Breite" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding BeamWidth}" FontFamily="{StaticResource Font.Mono}" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Höhe" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding BeamHeight}" FontFamily="{StaticResource Font.Mono}" />
                                        </DockPanel>
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="Basis-Z" Width="96" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding BeamBaseElevation}" FontFamily="{StaticResource Font.Mono}"
                                                     ToolTip.Tip="Unterkante (oft Deckenhöhe)" />
                                        </DockPanel>
                                    </StackPanel>

                                    <StackPanel Spacing="6" IsVisible="{Binding IsParametricSymbol}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <TextBlock Classes="eyebrow" Text="SMARTSYMBOL-PARAMETER" />
                                        <ItemsControl ItemsSource="{Binding SymbolParameters}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ParametricParamRowViewModel">
                                                    <DockPanel Margin="0,2">
                                                        <TextBlock Text="{Binding Name}" Width="96" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource Brush.TextMuted}" />
                                                        <TextBox Text="{Binding ValueText}" FontFamily="{StaticResource Font.Mono}" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel Spacing="6" IsVisible="{Binding IsBlockReference}">
                                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                        <TextBlock Classes="eyebrow" Text="BLOCK-ATTRIBUTE" />
                                        <ItemsControl ItemsSource="{Binding BlockAttributes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:BlockAttributeRowViewModel">
                                                    <DockPanel Margin="0,2">
                                                        <TextBlock Text="{Binding Key}" Width="96" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource Brush.TextMuted}" />
                                                        <TextBox Text="{Binding Value}" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="Feld +" Command="{Binding AddAttributeKeyCommand}"
                                                    ToolTip.Tip="Neues Attributfeld hinzufügen" />
                                            <TextBox Text="{Binding NewAttributeKey}" PlaceholderText="Neues Feld (z. B. Raumname)" />
                                        </DockPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Teilbilder ===== -->
                    <TabItem ToolTip.Tip="Teilbilder">
                        <TabItem.Header>
                            <Border Classes="tabicon">
                                <Path Classes="icotab" Width="22" Height="22" Data="{StaticResource Icon.Sheets}" />
                            </Border>
                        </TabItem.Header>
                        <DockPanel Margin="10" DataContext="{Binding StructurePanel}" x:DataType="vm:StructurePanelViewModel">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                                <Button Content="▲" Command="{Binding MovePartialDrawingUpCommand}" ToolTip.Tip="Nach oben" />
                                <Button Content="▼" Command="{Binding MovePartialDrawingDownCommand}" ToolTip.Tip="Nach unten" />
                                <Button Content="Neu" Command="{Binding AddPartialDrawingCommand}" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding PartialDrawings}" SelectedItem="{Binding SelectedPartialDrawing}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PartialDrawingItemViewModel">
                                        <DockPanel>
                                            <ComboBox DockPanel.Dock="Left" SelectedIndex="{Binding StateIndex}"
                                                      Width="100" Margin="0,0,8,0" ToolTip.Tip="Aktiv / Passiv (gedimmt, snapbar) / Aus">
                                                <ComboBoxItem>Aktiv</ComboBoxItem>
                                                <ComboBoxItem>Passiv</ComboBoxItem>
                                                <ComboBoxItem>Aus</ComboBoxItem>
                                            </ComboBox>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2"
                                                        VerticalAlignment="Center" Margin="6,0,0,0"
                                                        ToolTip.Tip="Höhe für 3D: Basis-Z und Bauteilhöhe (Extrusion)">
                                                <TextBlock Text="Z" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                                                <TextBox Text="{Binding BaseHeightText}" Width="40" FontFamily="{StaticResource Font.Mono}" />
                                                <TextBlock Text="H" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                                                <TextBox Text="{Binding HeightText}" Width="40" FontFamily="{StaticResource Font.Mono}" />
                                            </StackPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2"
                                                        VerticalAlignment="Center" Margin="6,0,0,0"
                                                        ToolTip.Tip="Bezugsmaßstab 1:n (skaliert die Schraffurdichte)">
                                                <TextBlock Text="1:" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                                                <TextBox Text="{Binding ScaleDenominator}" Width="44" FontFamily="{StaticResource Font.Mono}" />
                                            </StackPanel>
                                            <Border DockPanel.Dock="Right" Classes="badge brand" Margin="6,0,0,0"
                                                    VerticalAlignment="Center" IsVisible="{Binding IsCurrent}"
                                                    ToolTip.Tip="Aktuelles Teilbild – neue Geometrie landet hier">
                                                <TextBlock Text="Aktuell" />
                                            </Border>
                                            <TextBox Text="{Binding Name}" BorderThickness="0" Background="Transparent"
                                                     VerticalAlignment="Center" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ===== Layer ===== -->
                    <TabItem ToolTip.Tip="Layer">
                        <TabItem.Header>
                            <Border Classes="tabicon">
                                <Path Classes="icotab" Width="22" Height="22" Data="{StaticResource Icon.Layers}" />
                            </Border>
                        </TabItem.Header>
                        <DockPanel Margin="10" DataContext="{Binding StructurePanel}" x:DataType="vm:StructurePanelViewModel">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                                <Button Content="Neu" Command="{Binding AddLayerCommand}" />
                                <Button Content="Standard-Layer" Command="{Binding AddStandardLayersCommand}"
                                        ToolTip.Tip="Professionellen Standard-Layersatz einfügen" />
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                                <TextBlock Classes="eyebrow" Text="LAYER-FAVORITEN (STATUS-SÄTZE)" />
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Speichern" Command="{Binding SaveFavoriteCommand}"
                                            ToolTip.Tip="Aktuelle Layer-Status als Favorit speichern" />
                                    <TextBox Text="{Binding NewFavoriteName}" PlaceholderText="Favoritenname" />
                                </DockPanel>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                                        <Button Content="Anwenden" Command="{Binding ApplyFavoriteCommand}" />
                                        <Button Content="Entfernen" Command="{Binding RemoveFavoriteCommand}" />
                                    </StackPanel>
                                    <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding LayerFavorites}"
                                              SelectedItem="{Binding SelectedFavorite}" />
                                </DockPanel>
                            </StackPanel>

                            <Border DockPanel.Dock="Bottom" Margin="0,10,0,0" Padding="10" CornerRadius="6"
                                    Background="{DynamicResource Brush.SurfaceSunken}" BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1"
                                    IsVisible="{Binding SelectedLayer, Converter={x:Static converters:ObjectConverters.IsNotNull}}">
                                <StackPanel Spacing="8">
                                    <DockPanel>
                                        <TextBlock Classes="eyebrow" Text="FARBE" />
                                        <TextBlock Text="{Binding SelectedLayer.ColorHex}" Classes="mono" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextMuted}" />
                                    </DockPanel>
                                    <Grid ColumnDefinitions="16,*,36" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center" />
                                        <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding SelectedLayer.ColorRed}" />
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SelectedLayer.ColorRed, StringFormat='{}{0:0}'}"
                                                   Classes="mono" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextMuted}" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center" />
                                        <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding SelectedLayer.ColorGreen}" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SelectedLayer.ColorGreen, StringFormat='{}{0:0}'}"
                                                   Classes="mono" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextMuted}" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center" />
                                        <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding SelectedLayer.ColorBlue}" />
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding SelectedLayer.ColorBlue, StringFormat='{}{0:0}'}"
                                                   Classes="mono" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextMuted}" />
                                    </Grid>
                                    <Border Height="22" CornerRadius="4" BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1"
                                            Background="{Binding SelectedLayer.ColorBrush}" />
                                    <TextBlock Classes="eyebrow" Text="LINIENTYP" Margin="0,4,0,0" />
                                    <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding SelectedLayer.LineTypeOptions}"
                                              SelectedItem="{Binding SelectedLayer.LineType}" />
                                    <TextBlock Classes="eyebrow" Text="LINIENSTÄRKE" Margin="0,4,0,0" />
                                    <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding SelectedLayer.LineWeightOptions}"
                                              SelectedItem="{Binding SelectedLayer.LineWeight}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate x:DataType="sys:Double">
                                                <TextBlock Text="{Binding Converter={x:Static conv:LineWeightLabelConverter.Instance}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <ListBox ItemsSource="{Binding Layers}" SelectedItem="{Binding SelectedLayer}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LayerItemViewModel">
                                        <DockPanel>
                                            <ComboBox DockPanel.Dock="Left" SelectedIndex="{Binding StateIndex}"
                                                      Width="108" Margin="0,0,6,0" ToolTip.Tip="Aktiviert / Gesperrt / Deaktiviert">
                                                <ComboBoxItem>Aktiviert</ComboBoxItem>
                                                <ComboBoxItem>Gesperrt</ComboBoxItem>
                                                <ComboBoxItem>Deaktiviert</ComboBoxItem>
                                            </ComboBox>
                                            <Border DockPanel.Dock="Left" Width="14" Height="14" CornerRadius="3"
                                                    Margin="0,0,6,0" VerticalAlignment="Center"
                                                    BorderBrush="{DynamicResource Brush.BorderStrong}" BorderThickness="1"
                                                    Background="{Binding ColorBrush}" />
                                            <TextBox Text="{Binding Name}" BorderThickness="0" Background="Transparent"
                                                     VerticalAlignment="Center" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ===== Muster (Patterns) ===== -->
                    <TabItem ToolTip.Tip="Muster">
                        <TabItem.Header>
                            <Border Classes="tabicon">
                                <Path Classes="icotab" Width="22" Height="22" Data="{StaticResource Icon.Pattern}" />
                            </Border>
                        </TabItem.Header>
                        <ScrollViewer>
                            <StackPanel Margin="10" Spacing="8" DataContext="{Binding Patterns}" x:DataType="vm:PatternsViewModel">
                                <TextBlock Classes="eyebrow" Text="GLOBALE MUSTER" />
                                <ItemsControl ItemsSource="{Binding GlobalPatterns}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Brush.TextBody}" Margin="4,2" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                                <DockPanel>
                                    <TextBlock Classes="eyebrow" Text="PROJEKT-MUSTER" VerticalAlignment="Center" />
                                    <Button DockPanel.Dock="Right" Content="Entfernen" Command="{Binding RemoveProjectPatternCommand}" />
                                </DockPanel>
                                <ListBox MaxHeight="120" ItemsSource="{Binding ProjectPatterns}" SelectedItem="{Binding SelectedProjectPattern}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Margin="0,4,0,0" Padding="10" CornerRadius="6" Background="{DynamicResource Brush.SurfaceSunken}"
                                        BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="eyebrow" Text="NEUES PROJEKT-MUSTER" />
                                        <TextBox Text="{Binding NewName}" PlaceholderText="Name" />
                                        <DockPanel>
                                            <TextBlock Text="Winkel" Foreground="{DynamicResource Brush.TextMuted}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding NewAngle, StringFormat='{}{0:0}°'}" Classes="mono" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextMuted}" />
                                        </DockPanel>
                                        <Slider Minimum="0" Maximum="180" Value="{Binding NewAngle}" />
                                        <DockPanel>
                                            <TextBlock Text="Abstand" Foreground="{DynamicResource Brush.TextMuted}" DockPanel.Dock="Left" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding NewSpacing, StringFormat='{}{0:0}'}" Classes="mono" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextMuted}" />
                                        </DockPanel>
                                        <Slider Minimum="2" Maximum="120" Value="{Binding NewSpacing}" />
                                        <CheckBox Content="Kreuzschraffur" IsChecked="{Binding NewCross}" />
                                        <Grid ColumnDefinitions="16,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center" />
                                            <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding NewRed}" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center" />
                                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding NewGreen}" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center" />
                                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding NewBlue}" />
                                        </Grid>
                                        <Border Height="18" CornerRadius="4" BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1"
                                                Background="{Binding NewColorBrush}" />
                                        <Button Content="Hinzufügen" HorizontalAlignment="Right" Command="{Binding AddProjectPatternCommand}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Textstile ===== -->
                    <TabItem ToolTip.Tip="Textstile">
                        <TabItem.Header>
                            <Border Classes="tabicon">
                                <Path Classes="icotab" Width="22" Height="22" Data="{StaticResource Icon.Text}" />
                            </Border>
                        </TabItem.Header>
                        <DockPanel Margin="10" DataContext="{Binding TextStyles}" x:DataType="vm:TextStylesViewModel">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                                <Button Content="Neu" Command="{Binding AddStyleCommand}" />
                                <Button Content="Entfernen" Command="{Binding RemoveStyleCommand}" />
                            </StackPanel>

                            <Border DockPanel.Dock="Bottom" Margin="0,10,0,0" Padding="10" CornerRadius="6"
                                    Background="{DynamicResource Brush.SurfaceSunken}" BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1"
                                    IsVisible="{Binding CanEdit}">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="eyebrow" Text="STIL BEARBEITEN" />
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Name" Foreground="{DynamicResource Brush.TextMuted}" />
                                        <TextBox Text="{Binding Name}" />
                                    </StackPanel>
                                    <StackPanel Spacing="3">
                                        <TextBlock Text="Schriftart (leer = Standard)" Foreground="{DynamicResource Brush.TextMuted}" />
                                        <TextBox Text="{Binding FontFamily}" PlaceholderText="Standard" />
                                    </StackPanel>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <StackPanel Grid.Column="0" Spacing="3">
                                            <TextBlock Text="Höhe" Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding HeightText}" FontFamily="{StaticResource Font.Mono}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="3">
                                            <TextBlock Text="Breitenfaktor" Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding WidthFactorText}" FontFamily="{StaticResource Font.Mono}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <ListBox ItemsSource="{Binding Styles}" SelectedItem="{Binding SelectedStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="documents:TextStyle">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding FontFamily}"
                                                       Foreground="{DynamicResource Brush.TextFaint}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                    <!-- ===== Blöcke ===== -->
                    <TabItem ToolTip.Tip="Blöcke">
                        <TabItem.Header>
                            <Border Classes="tabicon">
                                <Path Classes="icotab" Width="22" Height="22" Data="{StaticResource Icon.Block}" />
                            </Border>
                        </TabItem.Header>
                        <DockPanel Margin="10" DataContext="{Binding Blocks}" x:DataType="vm:BlocksViewModel">
                            <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" Foreground="{DynamicResource Brush.TextMuted}" TextWrapping="Wrap"
                                       Text="Auswahl zu einem Block zusammenfassen, dann beliebig oft einfügen." />
                            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Button DockPanel.Dock="Right" Content="Aus Auswahl" Command="{Binding CreateBlockCommand}"
                                        ToolTip.Tip="Block aus der aktuellen Auswahl erstellen" />
                                <TextBox Text="{Binding NewBlockName}" PlaceholderText="Blockname" />
                            </DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="0,8,0,0">
                                <Button Content="Einfügen" Command="{Binding InsertBlockCommand}" />
                                <Button Content="Entfernen" Command="{Binding RemoveBlockCommand}" />
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Blocks}" SelectedItem="{Binding SelectedBlock}" />
                        </DockPanel>
                    </TabItem>

                    <!-- ===== Bibliothek ===== -->
                    <TabItem ToolTip.Tip="Symbolbibliothek">
                        <TabItem.Header>
                            <Border Classes="tabicon">
                                <Path Classes="icotab" Width="22" Height="22" Data="{StaticResource Icon.Library}" />
                            </Border>
                        </TabItem.Header>
                        <DockPanel Margin="10" DataContext="{Binding Library}" x:DataType="vm:LibraryViewModel">
                            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                                <TextBlock Classes="eyebrow" Text="DOKUMENTBLOCK → BIBLIOTHEK" />
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Speichern" Command="{Binding SaveToLibraryCommand}"
                                            ToolTip.Tip="Gewählten Dokumentblock projektübergreifend speichern" />
                                    <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding DocumentBlocks}"
                                              SelectedItem="{Binding SelectedDocumentBlock}" />
                                </DockPanel>
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="0,8,0,0">
                                <Border Height="150" CornerRadius="4" Background="{DynamicResource Brush.SurfaceSunken}"
                                        BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1">
                                    <Image Source="{Binding Preview}" Stretch="Uniform" Margin="4" />
                                </Border>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Button Content="Einfügen" Command="{Binding InsertSymbolCommand}" />
                                    <Button Content="Aktualisieren" Command="{Binding RefreshLibraryCommand}" />
                                </StackPanel>
                                <TextBlock Text="{Binding Status}" Foreground="{DynamicResource Brush.StatusOk}" TextWrapping="Wrap" />
                            </StackPanel>

                            <ListBox ItemsSource="{Binding Symbols}" SelectedItem="{Binding SelectedSymbol}" />
                        </DockPanel>
                    </TabItem>

                    <!-- ===== Smartsymbole (parametrisch) ===== -->
                    <TabItem ToolTip.Tip="Smartsymbole">
                        <TabItem.Header>
                            <Border Classes="tabicon">
                                <Path Classes="icotab" Width="22" Height="22" Data="{StaticResource Icon.Smart}" />
                            </Border>
                        </TabItem.Header>
                        <DockPanel Margin="10" DataContext="{Binding SmartSymbols}" x:DataType="vm:SmartSymbolViewModel">
                            <StackPanel DockPanel.Dock="Top" Spacing="4" Margin="0,0,0,8">
                                <TextBlock Classes="eyebrow" Text="PARAMETRISCHES SYMBOL" />
                                <ComboBox HorizontalAlignment="Stretch" ItemsSource="{Binding Definitions}"
                                          SelectedItem="{Binding SelectedDefinition}" />
                            </StackPanel>

                            <StackPanel DockPanel.Dock="Bottom" Spacing="6" Margin="0,8,0,0">
                                <Border Height="150" CornerRadius="4" Background="{DynamicResource Brush.SurfaceSunken}"
                                        BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1">
                                    <Image Source="{Binding Preview}" Stretch="Uniform" Margin="4" />
                                </Border>
                                <Button Content="Einfügen" HorizontalAlignment="Left" Command="{Binding InsertCommand}" />
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding Parameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SmartSymbolParamRowViewModel">
                                        <DockPanel Margin="0,2">
                                            <TextBlock Text="{Binding Name}" Width="90" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource Brush.TextMuted}" />
                                            <TextBox Text="{Binding ValueText}" FontFamily="{StaticResource Font.Mono}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </TabItem>

                    <!-- ===== Assistent ===== -->
                    <TabItem ToolTip.Tip="Assistent">
                        <TabItem.Header>
                            <Border Classes="tabicon">
                                <Path Classes="icotab" Width="22" Height="22" Data="{StaticResource Icon.Assistant}" />
                            </Border>
                        </TabItem.Header>
                        <DockPanel Margin="10">
                            <TextBlock DockPanel.Dock="Top" Margin="0,0,0,6" Foreground="{DynamicResource Brush.TextMuted}" TextWrapping="Wrap"
                                       Text="Doppelklick auf eine Vorlage übernimmt Werkzeug, Bauteil-Maße (Dicke/Höhe/Z), Layer und Linienstil." />
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="0,8,0,0">
                                <Button Content="Auswahl als Vorlage" Command="{Binding AddSelectionAsTemplateCommand}" />
                                <Button Content="Entfernen" Command="{Binding Assistant.RemoveSelectedCommand}" />
                            </StackPanel>
                            <ListBox x:Name="AssistantList" ItemsSource="{Binding Assistant.Templates}"
                                     SelectedItem="{Binding Assistant.SelectedTemplate}"
                                     DoubleTapped="OnAssistantDoubleTapped">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AssistantItemViewModel">
                                        <DockPanel>
                                            <Border DockPanel.Dock="Left" Width="26" CornerRadius="2"
                                                    VerticalAlignment="Center" Margin="0,0,8,0"
                                                    Height="{Binding PreviewWidth}" Background="{Binding PreviewBrush}" />
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding ToolLabel}" Foreground="{DynamicResource Brush.TextFaint}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" />
                                                <TextBlock Text="{Binding Detail}" FontSize="11"
                                                           Foreground="{DynamicResource Brush.TextFaint}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>
    </DockPanel>

</Window>
