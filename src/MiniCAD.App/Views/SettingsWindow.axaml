<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniCAD.App.ViewModels"
        xmlns:controls="using:MiniCAD.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="640"
        x:Class="MiniCAD.App.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Einstellungen"
        Width="520" Height="640"
        MinWidth="420" MinHeight="420"
        Background="{DynamicResource Brush.SurfaceApp}"
        Foreground="{DynamicResource Brush.TextBody}"
        CanResize="True" WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:SettingsViewModel/>
    </Design.DataContext>

    <DockPanel Margin="14">
        <Button DockPanel.Dock="Bottom" Content="Schließen" HorizontalAlignment="Right"
                Margin="0,12,0,0" Click="OnClose" />

        <TabControl>

            <TabItem Header="Allgemein">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="6,12,12,12" Spacing="16">
                        <TextBlock Text="Start" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextMuted}" />
                        <CheckBox Content="Beim Start zuletzt geöffnetes Projekt laden"
                                  IsChecked="{Binding OpenLastProjectOnStartup}" />

                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />

                        <TextBlock Text="Darstellung" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextMuted}" />
                        <CheckBox Content="Dunkles Design (Dark Mode)" IsChecked="{Binding IsDarkMode}" />
                        <CheckBox Content="Raster anzeigen" IsChecked="{Binding ShowGrid}" />

                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />

                        <TextBlock Text="Eingabe" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextMuted}" />
                        <CheckBox Content="Punkt statt Komma als Dezimaltrennzeichen"
                                  IsChecked="{Binding UseDecimalPoint}" />

                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />

                        <DockPanel>
                            <TextBlock Text="Hintergrundfarbe (Zeichenfläche)" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.TextMuted}" DockPanel.Dock="Left" />
                            <TextBlock Text="{Binding BackgroundHex}" Foreground="{DynamicResource Brush.TextFaint}"
                                       HorizontalAlignment="Right" />
                        </DockPanel>

                        <Grid ColumnDefinitions="20,*,40" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center" />
                            <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding BackgroundRed}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding BackgroundRed, StringFormat='{}{0:0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center" />
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding BackgroundGreen}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding BackgroundGreen, StringFormat='{}{0:0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center" />
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding BackgroundBlue}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding BackgroundBlue, StringFormat='{}{0:0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>

                        <Border Height="40" CornerRadius="4" Background="{Binding BackgroundBrush}"
                                BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Tastenkürzel">
                <DockPanel Margin="6,12" DataContext="{Binding Shortcuts}" x:DataType="vm:ShortcutsViewModel">
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Alle zurücksetzen" Command="{Binding ResetAllCommand}" />
                        <TextBlock Text="Tastenkürzel für Werkzeuge und Funktionen"
                                   Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                    </DockPanel>

                    <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0" Foreground="{DynamicResource Brush.TextFaint}" TextWrapping="Wrap"
                               Text="Feld anklicken und die gewünschte Taste(nkombination) drücken. Entf löscht die Belegung." />

                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ShortcutItemViewModel">
                                    <Grid ColumnDefinitions="*,150,Auto" Margin="0,3" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" />
                                        <controls:GestureCaptureBox Grid.Column="1" Text="{Binding Gesture, Mode=TwoWay}" />
                                        <Button Grid.Column="2" Content="Standard" Command="{Binding ResetCommand}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>

</Window>
