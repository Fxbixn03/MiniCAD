<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MiniCAD.App.ViewModels"
        xmlns:toolbar="using:MiniCAD.App.ViewModels.Toolbar"
        xmlns:controls="using:MiniCAD.App.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="760" d:DesignHeight="560"
        x:Class="MiniCAD.App.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Einstellungen"
        Width="760" Height="560"
        MinWidth="600" MinHeight="420"
        Background="{DynamicResource Brush.SurfaceApp}"
        Foreground="{DynamicResource Brush.TextBody}"
        CanResize="True" WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:SettingsViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="220,*" RowDefinitions="Auto,*,Auto">

        <!-- Top-left: search -->
        <TextBox Grid.Row="0" Grid.Column="0" Margin="12,12,6,8" PlaceholderText="Suchen…"
                 Text="{Binding SearchText}" />

        <!-- Top-right: current section title (large) -->
        <TextBlock Grid.Row="0" Grid.Column="1" Margin="6,12,14,8" VerticalAlignment="Center"
                   Text="{Binding SelectedSectionTitle}" FontSize="22" FontWeight="SemiBold" />

        <!-- Left: section navigation list -->
        <ListBox Grid.Row="1" Grid.Column="0" Margin="12,0,6,0"
                 ItemsSource="{Binding Sections}" SelectedItem="{Binding SelectedSection}"
                 Background="{DynamicResource Brush.SurfacePanel}"
                 BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:SettingsSectionViewModel">
                    <TextBlock Text="{Binding Name}" Margin="4,6" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Right: section content -->
        <Border Grid.Row="1" Grid.Column="1" Margin="6,0,14,0"
                Background="{DynamicResource Brush.SurfacePanel}"
                BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1" CornerRadius="4">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Padding="16">

                <Panel>
                    <!-- Allgemein -->
                    <StackPanel Spacing="14" IsVisible="{Binding IsGeneral}">
                        <TextBlock Text="Start" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextMuted}" />
                        <CheckBox Content="Beim Start zuletzt geöffnetes Projekt laden"
                                  IsChecked="{Binding OpenLastProjectOnStartup}" />
                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                        <TextBlock Text="Eingabe" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextMuted}" />
                        <CheckBox Content="Punkt statt Komma als Dezimaltrennzeichen"
                                  IsChecked="{Binding UseDecimalPoint}" />
                    </StackPanel>

                    <!-- Darstellung -->
                    <StackPanel Spacing="14" IsVisible="{Binding IsDisplay}">
                        <TextBlock Text="Design" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextMuted}" />
                        <CheckBox Content="Dunkles Design (Dark Mode)" IsChecked="{Binding IsDarkMode}" />
                        <CheckBox Content="Raster anzeigen" IsChecked="{Binding ShowGrid}" />
                        <Border Height="1" Background="{DynamicResource Brush.BorderSubtle}" />
                        <DockPanel>
                            <TextBlock Text="Hintergrundfarbe (Zeichenfläche)" FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.TextMuted}" DockPanel.Dock="Left" />
                            <TextBlock Text="{Binding BackgroundHex}" Foreground="{DynamicResource Brush.TextFaint}"
                                       HorizontalAlignment="Right" />
                        </DockPanel>
                        <Grid ColumnDefinitions="20,*,40" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="R" VerticalAlignment="Center" />
                            <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding BackgroundRed}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding BackgroundRed, StringFormat='{}{0:0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="G" VerticalAlignment="Center" />
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding BackgroundGreen}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding BackgroundGreen, StringFormat='{}{0:0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="B" VerticalAlignment="Center" />
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" Value="{Binding BackgroundBlue}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding BackgroundBlue, StringFormat='{}{0:0}'}" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                        <Border Height="40" CornerRadius="4" Background="{Binding BackgroundBrush}"
                                BorderBrush="{DynamicResource Brush.BorderDefault}" BorderThickness="1" />
                    </StackPanel>

                    <!-- Werkzeugleiste -->
                    <StackPanel Spacing="12" IsVisible="{Binding IsToolbar}">
                      <StackPanel Spacing="12" DataContext="{Binding Toolbar}" x:DataType="toolbar:ToolbarViewModel">
                        <TextBlock Text="Sichtbare Werkzeuge" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextMuted}" />
                        <TextBlock Text="Einzelne Werkzeuge ein- oder ausblenden. Reihenfolge der Blöcke und Andocken erfolgt direkt in der Werkzeugleiste."
                                   Foreground="{DynamicResource Brush.TextFaint}" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="toolbar:ToolGroupViewModel">
                                    <StackPanel Margin="0,4,0,8" Spacing="2">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Brush.TextBody}" Margin="0,4" />
                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="toolbar:ToolbarItemViewModel">
                                                    <CheckBox Margin="8,1" Content="{Binding Label}" IsChecked="{Binding IsVisible}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </StackPanel>

                    <!-- Tastenkürzel -->
                    <Panel IsVisible="{Binding IsShortcuts}">
                      <DockPanel DataContext="{Binding Shortcuts}" x:DataType="vm:ShortcutsViewModel">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Content="Alle zurücksetzen" Command="{Binding ResetAllCommand}" />
                            <TextBlock Text="Tastenkürzel für Werkzeuge und Funktionen"
                                       Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" />
                        </DockPanel>
                        <TextBlock DockPanel.Dock="Bottom" Margin="0,8,0,0" Foreground="{DynamicResource Brush.TextFaint}" TextWrapping="Wrap"
                                   Text="Feld anklicken und die gewünschte Taste(nkombination) drücken. Entf löscht die Belegung." />
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ShortcutItemViewModel">
                                    <Grid ColumnDefinitions="*,150,Auto" Margin="0,3" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" />
                                        <controls:GestureCaptureBox Grid.Column="1" Text="{Binding Gesture, Mode=TwoWay}" />
                                        <Button Grid.Column="2" Content="Standard" Command="{Binding ResetCommand}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </DockPanel>
                    </Panel>
                </Panel>
            </ScrollViewer>
        </Border>

        <!-- Bottom: close -->
        <Button Grid.Row="2" Grid.Column="1" Content="Schließen" HorizontalAlignment="Right"
                Margin="0,12,14,12" Click="OnClose" />
    </Grid>

</Window>
